# Лендинг / бот «О проекте»: положите своё фото в assets/ (author.jpg, author.png, author.webp…)
# При деплое ./scripts/dev-up.sh при отсутствии файла копирует src/assets/logo.jpg → assets/author.jpg
BOT_TOKEN=
BOT_USERNAME=
ADMIN_USERNAME=

# webhook = без long polling (рекомендуется на VPS / РФ)
TELEGRAM_UPDATE_MODE=webhook
# Пустой «люкс»-URL: webhook = WEBAPP_PUBLIC_URL + этот путь. По умолчанию / (тот же хост, что и сайт).
TELEGRAM_WEBHOOK_PATH=/
TELEGRAM_WEBHOOK_SECRET=change_me_random_string
# TELEGRAM_WEBHOOK_URL=   # пусто → WEBAPP_PUBLIC_URL + TELEGRAM_WEBHOOK_PATH
# TELEGRAM_PROXY_URL=socks5://host:port   # только для setWebhook при блокировке API
TELEGRAM_REQUEST_TIMEOUT=90

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=

REDIS_URL=redis://redis:6379/0

API_PUBLISH_PORT=8000
WEBAPP_PUBLIC_URL=
# Опционально: отдельный секрет для Bearer-токенов браузерного Neural Map Hub; пусто → ключ из BOT_TOKEN.
# WEBAPP_SITE_SESSION_SECRET=
# Telegram Login OIDC (BotFather → Bot Settings → Web Login): Client ID, Secret, Allowed URLs
# TELEGRAM_OIDC_CLIENT_ID=
# TELEGRAM_OIDC_CLIENT_SECRET=
# TELEGRAM_OIDC_REDIRECT_URI=   # пусто → {WEBAPP_PUBLIC_URL}/api/webapp/auth/oidc/callback
# В BotFather Allowed URLs: домен сайта + тот же callback (с /api/webapp/…). Допустим и …/auth/oidc/callback (алиас).
# TELEGRAM_OIDC_SCOPES=openid profile
WEBAPP_DOMAIN=
ACME_EMAIL=

# --- Tribute (оплата) ---
# В Docker: TRIBUTE_WEBHOOK_PORT=0 — вебхук принимает FastAPI (контейнер api), не отдельный порт в боте.
# URL в кабинете Tribute: https://brainboosty.ai/tribute/webhook
TRIBUTE_WEBHOOK_PORT=0
TRIBUTE_WEBHOOK_PATH=/tribute/webhook
TRIBUTE_WEBHOOK_SECRET=
# TRIBUTE_WEBHOOK_HOST=0.0.0.0   # только если PORT>0 (локальный aiohttp в процессе бота, без Docker api)

TRIBUTE_APP_URL=https://t.me/tribute/app?startapp=...
TRIBUTE_APP_URL_PROMO_15=
TRIBUTE_APP_URL_FOREVER_DISC=
# TRIBUTE_PRODUCT_ID_MONTH=
# TRIBUTE_PRODUCT_ID_FOREVER=

PREMIUM_CHANNEL_USERNAME=your_channel

# --- OpenAI / DeepSeek (пустой ключ → локальный fallback) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.deepseek.com

# --- Прочее ---
THROTTLE_SECONDS=0.7
DAILY_HOOK_HOUR=10
DAILY_HOOK_MINUTE=0
# VIP_PRIVATE_CHANNEL_CHAT_ID=-100...
